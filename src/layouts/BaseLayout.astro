---
export interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'Fam Jam Events — DJ + DSLR Photo Booth · Thousand Oaks, CA',
  description = 'DJ + DSLR Photo Booth for birthdays, pool parties, milestones, and everything in between. Serving Thousand Oaks & surrounding areas.',
} = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700;800;900&family=Inter:wght@400;500;600&display=swap"
    rel="stylesheet"
  />
</head>
<body>
  <slot />
</body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
