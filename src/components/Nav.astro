---
export interface Props {
  currentPage?: string;
}
const { currentPage = '/' } = Astro.props;
---
<nav>
  <a href="/" class="nav-logo">Fam<span class="accent">Jam</span> Events</a>
  <ul class="nav-links" id="nav-links">
    <li><a href="/#dj-service">DJ</a></li>
    <li><a href="/#memory-lab">Photo Booth</a></li>
    <li><a href="/#pricing">Pricing</a></li>
    <li><a href="/#gallery">Gallery</a></li>
    <li><a href="/#collective">The Collective</a></li>
    <li><a href="/#vibe-lab">Vibe Lab</a></li>
    <li><a href="https://oasis.famjamevents.com" target="_blank" rel="noopener" class="nav-oasis">The Oasis ✦</a></li>
    <li class="nav-mobile-cta"><a href="/book" class="nav-cta">Book Now</a></li>
  </ul>
  <button class="nav-hamburger" id="nav-hamburger" aria-label="Toggle menu">
    <span></span><span></span><span></span>
  </button>
  <a href="/book" class="nav-cta nav-cta-desktop">Book Now</a>
</nav>

<script>
  const burger = document.getElementById('nav-hamburger');
  const links = document.getElementById('nav-links');
  burger?.addEventListener('click', () => {
    links?.classList.toggle('open');
    burger.classList.toggle('open');
  });
  // Close menu when a link is clicked
  links?.querySelectorAll('a').forEach(a => {
    a.addEventListener('click', () => {
      links.classList.remove('open');
      burger?.classList.remove('open');
    });
  });
</script>

<style>
  .nav-oasis {
    color: var(--cyan) !important;
    border-bottom-color: transparent !important;
  }
  .nav-oasis:hover {
    color: var(--cyan) !important;
    border-bottom-color: var(--cyan) !important;
    opacity: .85;
  }
</style>
