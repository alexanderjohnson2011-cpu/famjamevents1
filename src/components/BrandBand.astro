<section class="brand-band">
  <div class="brand-band-inner">
    <div class="brand-statement">
      <p class="brand-line">Elevated. Family-friendly. Never lame.</p>
      <p class="brand-desc">
        We're here to make your party the most fun it can be — tailored to your crowd and your
        style, but never at the expense of the vibe.
        <strong>From parents who know how to have a good time.</strong>
      </p>
    </div>
    <div class="brand-cards">
      <div class="brand-card brand-are">
        <h3>What We Are ✓</h3>
        <ul class="brand-list">
          <li>DJ sets built for mixed-age crowds</li>
          <li>Flexible timelines, any venue</li>
          <li>Kid-appropriate cool</li>
          <li>Pro gear, tight execution</li>
        </ul>
      </div>
      <div class="brand-card brand-not">
        <h3>What We're Not ✕</h3>
        <ul class="brand-list">
          <li>Scripted wedding intros</li>
          <li>Corny crowd games</li>
          <li>Ballroom energy</li>
          <li>Overproduced MC hype</li>
        </ul>
      </div>
    </div>
  </div>
</section>
