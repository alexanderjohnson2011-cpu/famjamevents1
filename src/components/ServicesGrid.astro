---
---
<!-- ══════════════════════════════════ PRICING -->
<section class="section services-section" id="pricing">
  <div class="section-inner">
    <div class="centered">
      <div class="section-label">Two Vendors. One Booking.</div>
      <h2>Pick Your Setup</h2>
      <p class="sub" style="margin:0 auto 0;">Book one or both. Either way, we handle everything so you don't have to think about it day-of.</p>
    </div>

    <div class="services-grid" style="margin-top:48px;">

      <!-- Bundle first in DOM so it appears first on mobile -->
      <div class="svc-card featured svc-bundle">
        <span class="svc-icon">🎛️📸</span>
        <div class="svc-price">$800</div>
        <div class="svc-name">DJ + Photo Booth Bundle</div>
        <div class="svc-desc">3 hours. One booking, two vendors, zero day-of chaos. Save $400.</div>
        <ul class="svc-features">
          <li>Everything in DJ Service</li>
          <li>Everything in Photo Booth</li>
          <li>Coordinated setup — we figure out logistics together</li>
          <li>One contact for both, start to finish</li>
        </ul>
      </div>

      <!-- DJ card — collapsible on mobile -->
      <div class="svc-card svc-collapsible svc-dj">
        <span class="svc-icon">🎛️</span>
        <div class="svc-price">$600</div>
        <div class="svc-name">DJ Service</div>
        <button class="svc-toggle" aria-expanded="false">
          See what's included <span class="svc-chevron">›</span>
        </button>
        <div class="svc-body">
          <div class="svc-desc">3 hours. Your crowd will be on the floor. Both the grandmas and the toddlers.</div>
          <ul class="svc-features">
            <li>Set built around your music preferences</li>
            <li>Three DJs rotating through the event</li>
            <li>Fog machine + lights for night events</li>
            <li>Day-of scripting and mic included</li>
          </ul>
        </div>
      </div>

      <!-- Photo Booth card — collapsible on mobile -->
      <div class="svc-card svc-collapsible svc-booth">
        <span class="svc-icon">📸</span>
        <div class="svc-price">$600</div>
        <div class="svc-name">Photo Booth</div>
        <button class="svc-toggle" aria-expanded="false">
          See what's included <span class="svc-chevron">›</span>
        </button>
        <div class="svc-body">
          <div class="svc-desc">3 hours. Walk away with actual prints, not just a shared album link nobody opens.</div>
          <ul class="svc-features">
            <li>Real DSLR camera + flattering lighting</li>
            <li>Custom theme-matched print design</li>
            <li>Onsite attendant the whole time</li>
            <li>400+ high-res digital images per event</li>
          </ul>
        </div>
      </div>

    </div>

    <div class="services-addon-row">
      <div class="addon-card">
        <span class="addon-chip">Add-On</span>
        <div class="addon-body">
          <h4>Party Photos &amp; Social Reel</h4>
          <p>We capture photos and short video clips throughout the event and cut them into a social reel. Not a full event photographer — just us documenting the vibe as it happens.</p>
        </div>
        <div class="addon-price">$200<span>add to any package</span></div>
      </div>
    </div>

    <div class="services-cta">
      <a href="#cta" class="btn btn-pink">Lock In Your Date ✦</a>
    </div>
  </div>
</section>

<script>
  document.querySelectorAll('.svc-toggle').forEach(btn => {
    btn.addEventListener('click', () => {
      const card = btn.closest('.svc-collapsible');
      const isOpen = card.classList.toggle('is-open');
      btn.setAttribute('aria-expanded', String(isOpen));
    });
  });
</script>
