---
---
<section class="section services-section" id="services">
  <div class="section-inner">
    <div class="centered">
      <div class="section-label">Two Vendors. One Booking.</div>
      <h2>One Setup Plan.</h2>
      <p class="sub" style="margin:0 auto 0;">
        A DJ and a DSLR Photo Booth, booked together — so your party has music that moves people
        and prints they actually walk away with. Three DJs in rotation. Real camera. Real lighting.
        Real prints.
      </p>
    </div>

    <div class="services-grid" id="pricing">
      <!-- DJ Only -->
      <div class="svc-card">
        <span class="svc-icon">🎛️</span>
        <div class="svc-price">$600</div>
        <div class="svc-name">DJ Only</div>
        <div class="svc-desc">3 hours. Your kids will be on the floor. So will their parents.</div>
        <ul class="svc-features">
          <li>Reads the room and adjusts on the fly</li>
          <li>Curated for your specific crowd</li>
          <li>Kid-appropriate clean edits</li>
          <li>Request-driven, reads the room</li>
        </ul>
      </div>

      <!-- Photo Booth Only -->
      <div class="svc-card">
        <span class="svc-icon">📸</span>
        <div class="svc-price">$600</div>
        <div class="svc-name">Photo Booth Only</div>
        <div class="svc-desc">3 hours. Walk away with actual prints, not just a shared album link.</div>
        <ul class="svc-features">
          <li>Real DSLR camera + flattering lighting</li>
          <li>Custom theme-matched template</li>
          <li>Onsite attendant</li>
          <li>Digital gallery with hi-res images</li>
        </ul>
      </div>

      <!-- Bundle — Featured -->
      <div class="svc-card featured">
        <span class="svc-icon">🎛️📸</span>
        <div class="svc-price">$800</div>
        <div class="svc-name">DJ + Photo Booth Bundle</div>
        <div class="svc-desc">3 hours. One booking, two vendors, zero day-of chaos.</div>
        <ul class="svc-features">
          <li>Live DJ set, curated for your crowd</li>
          <li>DSLR Photo Booth with attendant</li>
          <li>Custom print templates per event</li>
          <li>Digital gallery included</li>
        </ul>
      </div>
    </div>

    <!-- Add-on strip -->
    <div class="services-addon-row">
      <div class="addon-card">
        <span class="addon-chip">Add-On</span>
        <div class="addon-body">
          <h4>Party Photos &amp; Social Reel</h4>
          <p>
            We capture photos and short video clips throughout the event and cut them into a social
            media reel. Not a full event photographer — this is us documenting the vibe as it happens.
          </p>
        </div>
        <div class="addon-price">$200<span>add to any package</span></div>
      </div>
    </div>

    <div class="services-cta">
      <a href="/book" class="btn btn-cyan">Check Availability →</a>
    </div>
  </div>
</section>
