---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import ServicesGrid from '../components/ServicesGrid.astro';
import Footer from '../components/Footer.astro';
---
<BaseLayout
  title="Book Fam Jam Events — DJ + Photo Booth · Thousand Oaks"
  description="Check availability and book your date. Weekends fill up fast in the 805."
>
  <Nav currentPage="/book" />

  <!-- Page header -->
  <section class="section book-section" style="padding-bottom:0;">
    <div class="section-inner centered">
      <div class="section-label">Let's Do This</div>
      <h2>Book Your Event</h2>
      <p class="sub" style="margin:0 auto 48px;">
        Weekends fill up fast. Drop us your details and we'll get back to you within 24 hours to
        confirm availability and talk through your party.
      </p>

      <div class="book-form-wrap">
        <form
          name="booking"
          method="POST"
          data-netlify="true"
          netlify-honeypot="bot-field"
          action="/book/success"
        >
          <!-- Netlify honeypot -->
          <input type="hidden" name="form-name" value="booking" />
          <p hidden><label>Don't fill this out: <input name="bot-field" /></label></p>

          <div class="form-row">
            <div class="form-field">
              <label for="name">Your Name</label>
              <input type="text" id="name" name="name" placeholder="Alex Johnson" required />
            </div>
            <div class="form-field">
              <label for="email">Email Address</label>
              <input type="email" id="email" name="email" placeholder="you@example.com" required />
            </div>
          </div>

          <div class="form-row">
            <div class="form-field">
              <label for="phone">Phone / Text</label>
              <input type="tel" id="phone" name="phone" placeholder="(805) 555-0100" />
            </div>
            <div class="form-field">
              <label for="date">Event Date</label>
              <input type="date" id="date" name="date" required />
            </div>
          </div>

          <div class="form-field">
            <label for="eventType">Event Type</label>
            <select id="eventType" name="eventType" required>
              <option value="">Select your event type...</option>
              <option value="birthday">Birthday Party</option>
              <option value="pool">Pool Party</option>
              <option value="graduation">Graduation</option>
              <option value="family">Family Reunion</option>
              <option value="celebration">General Celebration</option>
              <option value="other">Other</option>
            </select>
          </div>

          <div class="form-field">
            <label for="package">Package Interest</label>
            <select id="package" name="package" required>
              <option value="">What are you thinking?</option>
              <option value="dj">DJ Only — $500</option>
              <option value="booth">Photo Booth Only — $600</option>
              <option value="bundle">DJ + Photo Booth Bundle — $800 ★</option>
              <option value="addon">Bundle + Social Reel Add-On — $1,000</option>
              <option value="unsure">Not sure yet — help me decide</option>
            </select>
          </div>

          <div class="form-field">
            <label for="guestCount">Approximate Guest Count</label>
            <select id="guestCount" name="guestCount">
              <option value="">How many people?</option>
              <option value="under25">Under 25</option>
              <option value="25-50">25–50</option>
              <option value="50-100">50–100</option>
              <option value="100+">100+</option>
            </select>
          </div>

          <div class="form-field">
            <label for="message">Anything else we should know?</label>
            <textarea
              id="message"
              name="message"
              placeholder="Tell us about your party — theme, venue, crowd mix, must-play songs, whatever's on your mind."
            ></textarea>
          </div>

          <button type="submit" class="btn btn-pink form-submit">Send My Request ✦</button>
        </form>
      </div>

      <!-- Contact fallback -->
      <p style="margin-top:24px; font-size:.85rem; color:var(--muted);">
        Prefer to text? Reach us at
        <a href="tel:3124149698" style="color:var(--cyan); font-weight:600;">312-414-9698</a>
      </p>
    </div>
  </section>

  <!-- Pricing reference -->
  <ServicesGrid />

  <Footer />
</BaseLayout>
